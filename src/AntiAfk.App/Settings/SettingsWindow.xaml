<Window x:Class="AntiAfk.App.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AntiAFK"
        Height="290"
        Width="560"
        Icon="pack://application:,,,/Assets/app.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <StackPanel Margin="16">
        <TextBlock x:Name="LanguageLabel" Margin="0,0,0,4"/>
        <ComboBox x:Name="LanguageCombo" Width="200" HorizontalAlignment="Left" Margin="0,0,0,12"/>

        <TextBlock x:Name="LauncherPathLabel" Margin="0,0,0,4"/>
        <DockPanel Margin="0,0,0,12">
            <Button x:Name="BrowseButton" Content="Browse" DockPanel.Dock="Right" Width="90" Margin="8,0,0,0" Click="BrowseButton_Click"/>
            <TextBox x:Name="LauncherPathText"/>
        </DockPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelButton" Width="100" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Width="100" Click="SaveButton_Click"/>
        </StackPanel>

        <TextBlock x:Name="CreditsText"
                   Margin="0,16,0,0"
                   FontSize="11"
                   Foreground="#6B7280"
                   TextWrapping="Wrap"/>
    </StackPanel>
</Window>
